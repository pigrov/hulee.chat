{
  "name": "hulee",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm db:check && pnpm i18n:check && pnpm encoding:check && pnpm branding:check && pnpm native:check && pnpm inbox-v2:clean-slate:check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "api:dev": "pnpm --filter @hulee/api dev",
    "site:dev": "pnpm --filter @hulee/site exec next dev --hostname 127.0.0.1 --port 3002",
    "infra:up": "docker compose -f infra/docker-compose/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose/docker-compose.yml logs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db/run-migrations.mjs",
    "db:inbox-v2:install": "node scripts/db/install-inbox-v2.mjs",
    "db:inbox-v2:reset": "node scripts/db/reset-inbox-v2.mjs",
    "db:inbox-v2:rbac-dry-run": "tsx scripts/db/inbox-v2-rbac-dry-run.mjs",
    "db:inbox-v2:n1-bundle": "node scripts/db/fixtures/inbox-v2/generate-db008-n1-bundle.mjs",
    "db:seed:foundation": "tsx scripts/db/seed-foundation.ts",
    "test:inbox-v2:conversation-head-integrity": "vitest run --no-file-parallelism scripts/db/inbox-v2-conversation-timeline-head-migration.integration.test.mjs",
    "test:inbox-v2:source-registry-integrity": "vitest run --no-file-parallelism scripts/db/inbox-v2-source-registry-migration.integration.test.mjs",
    "test:inbox-v2:source": "node scripts/test/run-inbox-v2-source-gate.mjs",
    "test:inbox-v2:preserve": "vitest run --no-file-parallelism scripts/db/inbox-v2-rbac-dry-run.test.mjs scripts/db/inbox-v2-preserve-upgrade.integration.test.mjs scripts/db/inbox-v2-n1-upgrade.integration.test.mjs",
    "test:inbox-v2:postgres": "node scripts/db/run-inbox-v2-postgres-integration.mjs",
    "web:dev": "pnpm --filter @hulee/web exec next dev --hostname 127.0.0.1 --port 3001",
    "db:check": "node scripts/checks/db-check.mjs",
    "i18n:check": "node scripts/checks/i18n-check.mjs",
    "encoding:check": "node scripts/checks/encoding-check.mjs",
    "branding:check": "node scripts/checks/branding-check.mjs",
    "native:check": "node scripts/checks/native-check.mjs",
    "inbox-v2:clean-slate:check": "node scripts/checks/inbox-v2-clean-slate-check.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  }
}
