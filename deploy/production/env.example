POSTGRES_DB=hulee
POSTGRES_USER=hulee
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgres://hulee:change-this-password@postgres:5432/hulee

HULEE_DEPLOYMENT_TYPE=saas_shared
HULEE_LOG_LEVEL=info
HULEE_SECRET_ENCRYPTION_KEY=change-this-32-byte-secret-key!!
HULEE_INTERNAL_API_SECRET=change-this-internal-api-signing-secret
HULEE_WEB_TENANT_ID=tenant_local_1
HULEE_WEB_EMPLOYEE_ID=employee:local-dev

HULEE_WORKER_FEATURES=core
HULEE_PROVIDER_EGRESS_ENABLED=false
HULEE_PROVIDER_EGRESS_WORKER_FEATURES=telegram_bot,telegram_user,whatsapp_user,whatsapp_official
HULEE_EGRESS_PROFILE_ID=hulee_chat_vpn_gateway
HULEE_EGRESS_PROFILE_KIND=vpn_namespace
HULEE_EGRESS_PROFILE_STATUS=misconfigured
HULEE_EGRESS_OPERATOR_HINT=Enable provider-egress profile and configure VPN credentials before production Telegram/WhatsApp traffic.
HULEE_PROVIDER_EGRESS_PROFILE_ID=hulee_chat_vpn_gateway
HULEE_PROVIDER_EGRESS_PROFILE_STATUS=ready
HULEE_PROVIDER_EGRESS_OPERATOR_HINT=Provider traffic is routed through hulee_chat_vpn_gateway.

# S3-compatible object storage for message files and provider media.
# In production keep credentials only in server .env.
HULEE_OBJECT_STORAGE_ENDPOINT=http://minio:9000
HULEE_OBJECT_STORAGE_REGION=us-east-1
HULEE_OBJECT_STORAGE_BUCKET=hulee-files
HULEE_OBJECT_STORAGE_ACCESS_KEY_ID=
HULEE_OBJECT_STORAGE_SECRET_ACCESS_KEY=
HULEE_OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Provider egress profile. Keep credentials only in server .env, never in GitHub Secrets.
# Platform provider policies are desired state; direct <-> vpn_namespace also requires moving provider worker features to the matching compose service.
HULEE_EGRESS_GATEWAY_IMAGE=qmcgaw/gluetun:v3.40
HULEE_EGRESS_VPN_SERVICE_PROVIDER=nordvpn
HULEE_EGRESS_VPN_TYPE=openvpn
HULEE_EGRESS_OPENVPN_USER=
HULEE_EGRESS_OPENVPN_PASSWORD=
HULEE_EGRESS_SERVER_COUNTRIES=Netherlands
HULEE_EGRESS_OPENVPN_PROTOCOL=udp
HULEE_EGRESS_DOT=on
HULEE_EGRESS_DOT_PROVIDERS=cloudflare
HULEE_EGRESS_DOT_CACHING=on
HULEE_EGRESS_DOT_IPV6=off
HULEE_EGRESS_DNS_ADDRESS=127.0.0.1
HULEE_EGRESS_DNS_KEEP_NAMESERVER=off
HULEE_EGRESS_DNS_UPDATE_PERIOD=24h
HULEE_EGRESS_FIREWALL_OUTBOUND_SUBNETS=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
HULEE_EGRESS_HEALTHCHECK_URL=https://www.gstatic.com/generate_204
HULEE_EGRESS_PROBES_ENABLED=true
HULEE_EGRESS_PROBE_INTERVAL_MS=30000
HULEE_EGRESS_PROBE_TIMEOUT_MS=8000

# Generated by deployment for provider-egress. Do not hardcode in GitHub Secrets.
HULEE_PROVIDER_EGRESS_POSTGRES_HOST=127.0.0.1
HULEE_PROVIDER_EGRESS_API_HOST=127.0.0.1

# Bridge-compatible NordVPN gateway image. Use with HULEE_EGRESS_GATEWAY_IMAGE=bridge-nordvpn-gateway:latest.
HULEE_EGRESS_NORDVPN_TOKEN=
HULEE_EGRESS_NORDVPN_TECHNOLOGY=NordLynx
HULEE_EGRESS_NORDVPN_COUNTRY=
HULEE_EGRESS_NORDVPN_TARGETS=
HULEE_EGRESS_NORDVPN_HEALTHCHECK_URLS=
HULEE_EGRESS_NORDVPN_RECONNECT_AFTER_FAILURES=3
HULEE_EGRESS_NORDVPN_RECONNECT_COOLDOWN_SECONDS=300
HULEE_EGRESS_NORDVPN_HEALTHCHECK_TIMEOUT_SECONDS=8
HULEE_EGRESS_NORDVPN_ALLOW_SUBNETS=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
HULEE_EGRESS_NORDVPN_ALLOW_PORTS=
HULEE_EGRESS_NORDVPN_KILL_SWITCH=
HULEE_EGRESS_NORDVPN_LAN_DISCOVERY=

HULEE_SEED_TENANT_SLUG=local
HULEE_SEED_TENANT_NAME=Hulee Chat
HULEE_SEED_PRODUCT_NAME=Hulee
HULEE_SEED_ADMIN_EMAIL=admin@hulee.ru
HULEE_SEED_API_KEY=change-this-api-key
HULEE_SEED_API_KEY_NAME=Bootstrap API key
HULEE_SEED_TELEGRAM_CHANNEL_EXTERNAL_ID=telegram-local
HULEE_SEED_TELEGRAM_BOT_TOKEN_SECRET_REF=secret:tenant_local_1/channel-telegram/bot-token
HULEE_SEED_TELEGRAM_WEBHOOK_CONNECTOR_ID=tgwh_local
HULEE_SEED_TELEGRAM_WEBHOOK_SECRET_TOKEN_SECRET_REF=secret:tenant_local_1/channel-telegram/webhook-secret-token
